#!/usr/bin/env bash
set -euo pipefail

# ─── claude-proxy ─────────────────────────────────────────────────────────────
# Manages Claude Code profiles (accounts) and proxies.
#
# Profile commands:
#   claude-proxy profile list
#   claude-proxy profile create <n> [--from <source>] [--include-projects]
#   claude-proxy profile delete <n>
#   claude-proxy profile rename  <old> <new>
#   claude-proxy profile use     <n>
#   claude-proxy profile show    [<n>]
#   claude-proxy profile set-proxy     <profile> <proxy>
#   claude-proxy profile unset-proxy   <profile>
#   claude-proxy profile copy-settings <profile> --from <source> [--include-projects]
#
# Proxy commands:
#   claude-proxy proxy list
#   claude-proxy proxy create <n> <host:port> <user>
#   claude-proxy proxy delete <n>
#   claude-proxy proxy rename  <old> <new>
#   claude-proxy proxy set-password <n>
#   claude-proxy proxy show  <n>
#   claude-proxy proxy check <n>
#
# Shortcuts:
#   claude-proxy use <n>      → profile use
#   claude-proxy run <n>      → launch with profile (no global switch)
#   claude-proxy status          → full overview
#   claude-proxy check           → proxy check (active profile's proxy)
#   claude-proxy version / --version / -v
#   claude-proxy help / --help / -h
#   claude-proxy migrate         → migrate from v1 proxy.conf
#   claude-proxy update [--force] [--version <tag>]  → update/reinstall (preview + confirmation)
#   claude-proxy uninstall       → remove everything
# ─────────────────────────────────────────────────────────────────────────────

VERSION="2.2.0"

CONF_DIR="$HOME/.config/proxied-claude"
PROFILES_DIR="$CONF_DIR/profiles"
PROXIES_DIR="$CONF_DIR/proxies"
GATEWAYS_DIR="$CONF_DIR/gateways"
ACTIVE_FILE="$CONF_DIR/active_profile"
LOCK_DIR="$CONF_DIR/.lock"
LEGACY_CONF="$CONF_DIR/proxy.conf"

WRAPPER_PATH="/usr/local/bin/proxied-claude"
CTL_PATH="/usr/local/bin/claude-proxy"

# Files safe to copy between profiles (no auth, no history, no cache)
SETTINGS_FILES=(
  "settings.json"      # UI preferences, themes, MCP servers
  "CLAUDE.md"          # global Claude instructions
  "keybindings.json"   # custom keybindings
  "policy-limits.json" # usage policy overrides
)

# Directories safe to copy (shallow)
SETTINGS_DIRS=(
  "hooks"    # custom lifecycle hooks
  "plugins"  # installed plugins
)

# ── Output helpers ───────────────────────────────────────────────────────────

die()  { echo "ERROR: $*" >&2; exit 1; }
ok()   { echo "✅ $*"; }
info() { echo "   $*"; }
warn() { echo "⚠️  $*"; }
display_path() { printf '%s\n' "${1/#$HOME/~}"; }

# ── URL encoder (RFC 3986) ────────────────────────────────────────────────────
# Encodes a string for safe use in a URL (username or password component).
# Pure bash — no subshells, no external tools.
url_encode() {
  local string="$1" encoded="" i char
  for (( i=0; i<${#string}; i++ )); do
    char="${string:$i:1}"
    case "$char" in
      [a-zA-Z0-9._~-]) encoded+="$char" ;;
      *) printf -v char '%%%02X' "'$char"
         encoded+="$char" ;;
    esac
  done
  printf '%s' "$encoded"
}

# ── Core helpers ─────────────────────────────────────────────────────────────

ensure_dirs() { mkdir -p "$PROFILES_DIR" "$PROXIES_DIR" "$GATEWAYS_DIR"; }

# Returns 0 if dir exists and has data (excluding .DS_Store), 1 otherwise.
dir_has_data() {
  local dir="$1"
  [[ -d "$dir" ]] || return 1
  [[ -n "$(find "$dir" -mindepth 1 -maxdepth 1 -not -name ".DS_Store" -print -quit 2>/dev/null)" ]]
}

# Fast conf reader — grep-based, no fork, no source, no injection risk.
# Reads KEY="value" or KEY=value from a conf file.
read_conf() {
  local file="$1" var="$2" line
  line="$(grep -m1 "^${var}=" "$file" 2>/dev/null)" || true
  line="${line#*=}"
  line="${line#\"}"
  line="${line%\"}"
  printf '%s' "$line"
}

# Only allow safe characters — prevents path traversal
validate_name() {
  local name="$1" kind="${2:-name}"
  [[ -n "$name" ]] || die "$kind cannot be empty."
  [[ "$name" =~ ^[a-zA-Z0-9_-]+$ ]] || \
    die "Invalid $kind '$name'. Only letters, digits, hyphens and underscores allowed."
}

active_profile() {
  if [[ -f "$ACTIVE_FILE" && -s "$ACTIVE_FILE" ]]; then
    local val; val="$(tr -d '[:space:]' < "$ACTIVE_FILE")"
    [[ -n "$val" ]] && echo "$val" || echo "default"
  else
    echo "default"
  fi
}

# Atomic write — prevents partial reads.
write_active() {
  local tmp; tmp="$(mktemp "${ACTIVE_FILE}.XXXXXX")"
  echo "$1" > "$tmp"
  mv "$tmp" "$ACTIVE_FILE"
}

require_profile() {
  [[ -f "$PROFILES_DIR/${1}.conf" ]] || \
    die "Profile '$1' does not exist. Run: claude-proxy profile list"
}

require_proxy() {
  [[ -f "$PROXIES_DIR/${1}.conf" ]] || \
    die "Proxy '$1' does not exist. Run: claude-proxy proxy list"
}

require_gateway() {
  [[ -f "$GATEWAYS_DIR/${1}.conf" ]] || \
    die "Gateway '$1' does not exist. Run: claude-proxy gateway list"
}

require_interactive() {
  [[ -t 0 ]] || die "This command requires interactive input (stdin must be a terminal)."
}

keychain_service() { printf 'claude-proxy:%s\n' "${1}"; }

# Prompt for Y/N confirmation (default no). Returns 0 for Y, 1 otherwise.
# CR strip handles CRLF line endings from some terminals/redirections.
confirm() {
  local _c
  printf '%s' "$1" >&2; read -r _c
  _c="${_c%$'\r'}"
  [[ "${_c:-}" =~ ^[Yy]$ ]]
}

# Write helpers — single source of truth for conf file format.
# Add new fields here only; all write sites stay in sync automatically.
write_profile_conf() {
  local file="$1" dir="$2" proxy="$3" gateway="${4:-}"
  cat > "$file" <<EOF
CONFIG_VERSION=1
PROFILE_CLAUDE_DIR="${dir}"
PROFILE_PROXY="${proxy}"
PROFILE_GATEWAY="${gateway}"
EOF
}

write_proxy_conf() {
  local file="$1" host="$2" user="$3" svc="$4"
  cat > "$file" <<EOF
CONFIG_VERSION=1
PROXY_HOST="${host}"
PROXY_USER="${user}"
PROXY_KEYCHAIN_SERVICE="${svc}"
EOF
}

write_gateway_conf() {
  local file="$1" url="$2" svc="$3"
  cat > "$file" <<EOF
CONFIG_VERSION=1
GATEWAY_URL="${url}"
GATEWAY_KEYCHAIN_SERVICE="${svc}"
EOF
}

gateway_keychain_service() { printf 'claude-proxy-gateway:%s\n' "${1}"; }

# Resolve Claude dir for a profile (handles default special case)
profile_claude_dir() {
  local name="$1"
  local dir; dir="$(read_conf "$PROFILES_DIR/${name}.conf" PROFILE_CLAUDE_DIR)"
  if [[ -z "$dir" ]]; then
    [[ "$name" == "default" ]] && echo "$HOME/.claude" || echo "$HOME/.claude-${name}"
  else
    echo "$dir"
  fi
}

# ── Lock (mkdir-based, POSIX-portable) ───────────────────────────────────────
# Used only for mutating commands. Read-only commands skip locking.

lock_acquire() {
  local waited=0
  while ! mkdir "$LOCK_DIR" 2>/dev/null; do
    (( waited++ >= 5 )) && die "Another claude-proxy instance is running. Retry in a moment.
  If stuck, remove: $LOCK_DIR"
    sleep 1
  done
  trap 'rm -rf "$LOCK_DIR"' EXIT
}

lock_release() {
  rm -rf "$LOCK_DIR"
  # Reset trap — don't double-delete on exit
  trap - EXIT
}

# ── Copy settings ────────────────────────────────────────────────────────────

# Returns 0 if both .claude.json files contain a non-empty mcpServers key.
mcp_has_conflict() {
  command -v python3 >/dev/null 2>&1 || return 1
  python3 -c "
import json, sys
def has_mcp(p): return bool(json.load(open(p)).get('mcpServers'))
sys.exit(0 if has_mcp(sys.argv[1]) and has_mcp(sys.argv[2]) else 1)
" "$1" "$2" </dev/null 2>/dev/null
}

# Copies mcpServers from src .claude.json into dst .claude.json (creates dst if absent).
# Returns 0 if mcpServers were found and written, 1 if src had none.
mcp_copy_servers() {
  command -v python3 >/dev/null 2>&1 || { warn "python3 not found — mcpServers not copied"; return 1; }
  python3 -c "
import json, sys, os
src_mcp = json.load(open(sys.argv[1])).get('mcpServers', {})
if not src_mcp: sys.exit(1)
dst = json.load(open(sys.argv[2])) if os.path.exists(sys.argv[2]) else {}
dst['mcpServers'] = src_mcp
open(sys.argv[2], 'w').write(json.dumps(dst, indent=2) + '\n')
" "$1" "$2" </dev/null 2>/dev/null
}

do_copy_settings() {
  local src_dir="$1" dst_dir="$2" src_label="$3" dst_label="$4" \
        include_projects="${5:-0}"
  local copied=0
  mkdir -p "$dst_dir"

  # Locate .claude.json for each profile dir (for mcpServers handling).
  # Claude Code writes to CLAUDE_CONFIG_DIR/.claude.json; legacy default profile
  # wrote to ${dir}.json (i.e. ~/.claude.json) when CLAUDE_CONFIG_DIR was unset.
  local src_claude_json="" dst_claude_json=""
  if [[ -f "${src_dir}/.claude.json" ]]; then src_claude_json="${src_dir}/.claude.json"
  elif [[ -f "${src_dir}.json" ]]; then src_claude_json="${src_dir}.json"; fi
  if [[ -f "${dst_dir}/.claude.json" ]]; then dst_claude_json="${dst_dir}/.claude.json"
  elif [[ -f "${dst_dir}.json" ]]; then dst_claude_json="${dst_dir}.json"; fi

  # Pass 1: collect conflicts
  local conflicts=()
  for f in "${SETTINGS_FILES[@]}"; do
    [[ -f "$src_dir/$f" ]] || continue
    [[ -f "$dst_dir/$f" ]] && conflicts+=("$f")
  done
  for d in "${SETTINGS_DIRS[@]}"; do
    [[ -d "$src_dir/$d" ]] || continue
    for item in "$src_dir/$d"/*; do
      [[ -e "$item" ]] || continue
      [[ -e "$dst_dir/$d/$(basename "$item")" ]] && conflicts+=("$d/$(basename "$item")")
    done
  done

  if [[ "$include_projects" == "1" ]]; then
    shopt -s nullglob
    for proj_dir in "$src_dir/projects"/*/; do
      [[ -d "$proj_dir/memory" ]] || continue
      local repo; repo="$(basename "$proj_dir")"
      for mf in "$proj_dir/memory"/*; do
        [[ -e "$mf" ]] || continue
        [[ -e "$dst_dir/projects/$repo/memory/$(basename "$mf")" ]] && \
          conflicts+=("projects/$repo/memory/$(basename "$mf")")
      done
    done
    shopt -u nullglob
  fi

  # mcpServers conflict: both src and dst already have mcpServers
  if [[ -n "$src_claude_json" && -n "$dst_claude_json" ]]; then
    if mcp_has_conflict "$src_claude_json" "$dst_claude_json"; then
      conflicts+=(".claude.json (mcpServers)")
    fi
  fi

  # Resolve conflicts
  if [[ ${#conflicts[@]} -gt 0 ]]; then
    if [[ -t 0 ]]; then
      warn "${#conflicts[@]} item(s) already exist in '$dst_label' and will be overwritten:"
      for c in "${conflicts[@]}"; do info "  $c"; done
      echo ""
      confirm "  Overwrite? [y/N] " || return 1
      echo ""
    else
      die "${#conflicts[@]} conflicting item(s) in '$dst_label'. Run interactively to confirm overwrite."
    fi
  fi

  # Pass 2: copy files and dirs
  for f in "${SETTINGS_FILES[@]}"; do
    if [[ -f "$src_dir/$f" ]]; then
      cp "$src_dir/$f" "$dst_dir/$f"
      info "Copied $f"
      (( copied++ )) || true
    fi
  done
  # Rewrite claude profile dir paths in settings.json
  [[ -f "$dst_dir/settings.json" ]] && \
    sed -E -i '' "s|$HOME/\.claude(-[a-zA-Z0-9_-]*)?|$dst_dir|g" \
      "$dst_dir/settings.json"
  for d in "${SETTINGS_DIRS[@]}"; do
    if [[ -d "$src_dir/$d" ]]; then
      mkdir -p "$dst_dir/$d"
      local dir_copied=0
      for item in "$src_dir/$d"/*; do
        [[ -e "$item" ]] || continue
        cp -r "$item" "$dst_dir/$d/$(basename "$item")"
        (( dir_copied++ )) || true
      done
      if [[ $dir_copied -gt 0 ]]; then
        info "Copied $d/ ($dir_copied item(s))"
        (( copied++ )) || true
      fi
    fi
  done

  # Rewrite absolute plugin cache paths in copied plugin manifests.
  # Use | as delimiter so forward slashes in absolute paths are safe.
  # Profile names are validated to [a-zA-Z0-9_-] so no | characters possible.
  for _pf in "installed_plugins.json" "known_marketplaces.json"; do
    [[ -f "$dst_dir/plugins/$_pf" ]] && \
      sed -i '' "s|${src_dir}/plugins/|${dst_dir}/plugins/|g" \
        "$dst_dir/plugins/$_pf"
  done

  if [[ "$include_projects" == "1" ]]; then
    shopt -s nullglob
    for proj_dir in "$src_dir/projects"/*/; do
      [[ -d "$proj_dir/memory" ]] || continue
      local repo; repo="$(basename "$proj_dir")"
      mkdir -p "$dst_dir/projects/$repo/memory"
      for mf in "$proj_dir/memory"/*; do
        [[ -e "$mf" ]] || continue
        cp -r "$mf" "$dst_dir/projects/$repo/memory/$(basename "$mf")"
        (( copied++ )) || true
      done
    done
    shopt -u nullglob
  fi

  # Copy mcpServers from .claude.json (source replaces destination)
  if [[ -n "$src_claude_json" ]]; then
    local dst_cj
    if [[ -n "$dst_claude_json" ]]; then dst_cj="$dst_claude_json"
    elif [[ "$dst_dir" == "$HOME/.claude" ]]; then dst_cj="${dst_dir}.json"
    else dst_cj="${dst_dir}/.claude.json"; fi
    if mcp_copy_servers "$src_claude_json" "$dst_cj"; then
      info "Copied mcpServers (.claude.json)"
      (( copied++ )) || true
    fi
  fi

  if [[ $copied -eq 0 ]]; then
    info "No settings found in '$src_label' (nothing copied)"
  else
    ok "Settings copied from '$src_label' → '$dst_label'"
  fi
}

# ── Find profiles linked to a proxy ─────────────────────────────────────────

# Outputs space-separated list of profile names linked to the given proxy.
profiles_using_proxy() {
  local proxy_name="$1" result=""
  shopt -s nullglob
  for pf in "$PROFILES_DIR"/*.conf; do
    local linked; linked="$(read_conf "$pf" PROFILE_PROXY)"
    [[ "$linked" == "$proxy_name" ]] && result="${result}$(basename "$pf" .conf) "
  done
  shopt -u nullglob
  printf '%s' "$result"
}

profiles_using_gateway() {
  local gw_name="$1" result=""
  shopt -s nullglob
  for pf in "$PROFILES_DIR"/*.conf; do
    local linked; linked="$(read_conf "$pf" PROFILE_GATEWAY)"
    [[ "$linked" == "$gw_name" ]] && result="${result}$(basename "$pf" .conf) "
  done
  shopt -u nullglob
  printf '%s' "$result"
}

unlink_gateway_from_profiles() {
  local gw_name="$1"
  shopt -s nullglob
  for pf in "$PROFILES_DIR"/*.conf; do
    local linked; linked="$(read_conf "$pf" PROFILE_GATEWAY)"
    if [[ "$linked" == "$gw_name" ]]; then
      local pdir;  pdir="$(read_conf  "$pf" PROFILE_CLAUDE_DIR)"
      local proxy; proxy="$(read_conf "$pf" PROFILE_PROXY)"
      write_profile_conf "$pf" "$pdir" "$proxy" ""
      info "Unlinked gateway from profile '$(basename "$pf" .conf)'"
    fi
  done
  shopt -u nullglob
}

# Unlink proxy from all profiles that reference it.
unlink_proxy_from_profiles() {
  local proxy_name="$1"
  shopt -s nullglob
  for pf in "$PROFILES_DIR"/*.conf; do
    local linked; linked="$(read_conf "$pf" PROFILE_PROXY)"
    if [[ "$linked" == "$proxy_name" ]]; then
      local pdir;    pdir="$(read_conf    "$pf" PROFILE_CLAUDE_DIR)"
      local gateway; gateway="$(read_conf "$pf" PROFILE_GATEWAY)"
      write_profile_conf "$pf" "$pdir" "" "$gateway"
      info "Unlinked proxy from profile '$(basename "$pf" .conf)'"
    fi
  done
  shopt -u nullglob
}

# ── Migration (single source of truth) ───────────────────────────────────────

do_migrate() {
  local verbose="${1:-1}"

  if [[ ! -f "$LEGACY_CONF" ]]; then
    [[ "$verbose" == "1" ]] && info "No v1 config found (proxy.conf). Nothing to migrate." || true
    return 0
  fi
  echo "Migrating v1 config (proxy.conf) → v2 profiles/proxies..."
  echo ""

  local old_host old_user old_svc
  old_host="$(read_conf "$LEGACY_CONF" CLAUDE_PROXY_HOST)"
  old_user="$(read_conf "$LEGACY_CONF" CLAUDE_PROXY_USER)"
  old_svc="$(read_conf  "$LEGACY_CONF" CLAUDE_PROXY_KEYCHAIN_SERVICE)"
  old_svc="${old_svc:-claude-proxy}"

  ensure_dirs

  local has_proxy=false
  if [[ -n "$old_host" && -n "$old_user" ]]; then
    has_proxy=true
    local new_svc; new_svc="$(keychain_service "default")"

    local pass
    pass="$(security find-generic-password -a "$old_user" -s "$old_svc" -w 2>/dev/null || true)"
    if [[ -n "$pass" ]]; then
      security add-generic-password -a "$old_user" -s "$new_svc" -w "$pass" -U >/dev/null 2>&1 || true
      security delete-generic-password -a "$old_user" -s "$old_svc" >/dev/null 2>&1 || true
      ok "Proxy password migrated → Keychain: $new_svc"
      ok "Old Keychain entry '$old_svc' removed"
    else
      warn "Could not read password from Keychain (service=$old_svc, account=$old_user)"
      info "After migration, run: claude-proxy proxy set-password default"
    fi

    if [[ ! -f "$PROXIES_DIR/default.conf" ]]; then
      write_proxy_conf "$PROXIES_DIR/default.conf" "$old_host" "$old_user" "$new_svc"
      ok "Created proxies/default.conf ($old_user@$old_host)"
    else
      info "proxies/default.conf already exists — skipped"
    fi
  fi

  if [[ ! -f "$PROFILES_DIR/default.conf" ]]; then
    local linked=""
    [[ "$has_proxy" == "true" ]] && linked="default"
    write_profile_conf "$PROFILES_DIR/default.conf" "$HOME/.claude" "$linked" ""
    ok "Created profiles/default.conf → $HOME/.claude"
    [[ "$has_proxy" == "true" ]] && info "Proxy 'default' linked"
  else
    if [[ "$has_proxy" == "true" ]]; then
      local _cur_proxy; _cur_proxy="$(read_conf "$PROFILES_DIR/default.conf" PROFILE_PROXY)"
      if [[ -z "$_cur_proxy" ]]; then
        local _cur_dir; _cur_dir="$(read_conf "$PROFILES_DIR/default.conf" PROFILE_CLAUDE_DIR)"
        write_profile_conf "$PROFILES_DIR/default.conf" "$_cur_dir" "default" ""
        ok "Linked proxy 'default' to existing profiles/default.conf"
      else
        info "profiles/default.conf already exists — skipped"
      fi
    else
      info "profiles/default.conf already exists — skipped"
    fi
  fi

  if [[ ! -f "$ACTIVE_FILE" || ! -s "$ACTIVE_FILE" ]]; then
    write_active "default"
    ok "Active profile set to 'default'"
  fi

  rm "$LEGACY_CONF"
  echo ""
  ok "Migration complete!"
}

# ── Ensure default profile ───────────────────────────────────────────────────

ensure_default_profile() {
  ensure_dirs
  mkdir -p "$CONF_DIR/ide"
  if [[ ! -f "$PROFILES_DIR/default.conf" ]]; then
    write_profile_conf "$PROFILES_DIR/default.conf" "$HOME/.claude" ""
  fi
  if [[ ! -f "$ACTIVE_FILE" || ! -s "$ACTIVE_FILE" ]]; then
    write_active "default"
  fi
}

