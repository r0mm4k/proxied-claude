# ── profile subcommands ──────────────────────────────────────────────────────

cmd_profile() {
  local sub="${1:-}"; shift || true

  case "$sub" in

    list)
      local active; active="$(active_profile)"
      shopt -s nullglob
      local files=("$PROFILES_DIR"/*.conf)
      shopt -u nullglob
      if [[ ${#files[@]} -eq 0 ]]; then
        echo "  (no profiles yet — run: claude-proxy profile create <n>)"
        return
      fi
      echo ""
      printf "  %-20s  %-18s  %-30s\n" "PROFILE" "PROXY" "DIR"
      printf "  %-20s  %-18s  %-30s\n" "-------" "-----" "---"
      for f in "${files[@]}"; do
        local name; name="$(basename "$f" .conf)"
        local proxy;     proxy="$(read_conf "$f" PROFILE_PROXY)"
        local claude_dir; claude_dir="$(profile_claude_dir "$name")"
        local marker=""; [[ "$name" == "$active" ]] && marker="◀ active"
        printf "  %-20s  %-18s  %-30s  %s\n" \
          "$name" "${proxy:-(no proxy)}" "$(display_path "$claude_dir")" "$marker"
      done
      echo ""
      ;;

    create)
      # Parse args (no lock needed yet)
      local name="${1:-}"; shift || true
      [[ -n "$name" ]] || die "Usage: claude-proxy profile create <n> [--from <source>] [--include-projects]"
      validate_name "$name" "profile name"
      local copy_from="" include_projects=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --from) shift; copy_from="${1:-}"; shift ;;
          --include-projects) include_projects=1; shift ;;
          *) die "Unknown option: $1" ;;
        esac
      done
      [[ "$include_projects" == "1" && -z "$copy_from" ]] && \
        die "--include-projects requires --from <source>"
      [[ -n "$copy_from" ]] && validate_name "$copy_from" "source profile name"

      # Lock → create conf → release (short hold); dir handled below
      lock_acquire
      local conf="$PROFILES_DIR/${name}.conf"
      [[ ! -f "$conf" ]] || die "Profile '$name' already exists."

      local claude_dir="$HOME/.claude-${name}"
      write_profile_conf "$conf" "$claude_dir" ""
      lock_release

      local _login_note="Note: you need to log in to Claude the first time you use this profile"

      if dir_has_data "$claude_dir"; then
        if [[ -t 0 ]]; then
          echo ""
          warn "Directory $claude_dir already exists and contains data."
          echo "  Your previous session data and settings are preserved."
          echo ""
          local _fresh=""
          if confirm "  Start fresh and delete existing data? [y/N] "; then
            rm -rf "$claude_dir"
          else
            _login_note="Note: If your session expired, log in again when you first use this profile"
          fi
          echo ""
        else
          warn "Directory $claude_dir already exists and contains data — using as-is"
          _login_note="Note: If your session expired, log in again when you first use this profile"
        fi
      fi
      mkdir -p "$claude_dir"
      [[ -L "$claude_dir/ide" ]] || { rm -rf "$claude_dir/ide"; ln -s "$CONF_DIR/ide" "$claude_dir/ide"; }

      ok "Profile '$name' created"
      info "Claude dir : $(display_path "$claude_dir")"
      info "$_login_note"

      # Copy settings (no lock — only writes into the new profile's dir)
      if [[ -n "$copy_from" ]]; then
        require_profile "$copy_from"
        local src_dir; src_dir="$(profile_claude_dir "$copy_from")"
        do_copy_settings "$src_dir" "$claude_dir" "$copy_from" "$name" "$include_projects" || true
      elif [[ -t 0 ]]; then
        shopt -s nullglob
        local existing=("$PROFILES_DIR"/*.conf)
        shopt -u nullglob
        local candidates=()
        for f in "${existing[@]}"; do
          local pname; pname="$(basename "$f" .conf)"
          [[ "$pname" != "$name" ]] && candidates+=("$pname")
        done

        if [[ ${#candidates[@]} -gt 0 ]]; then
          echo ""
          echo "  Available profiles to copy settings from:"
          for c in "${candidates[@]}"; do printf "    %s\n" "$c"; done
          echo "    (skip)"
          echo ""
          printf '%s' "  Copy settings from profile? [profile name or Enter to skip]: " >&2; read -r _choice
          _choice="${_choice%$'\r'}"
          if [[ -n "$_choice" && "$_choice" != "skip" ]]; then
            if [[ -f "$PROFILES_DIR/${_choice}.conf" ]]; then
              local src_dir; src_dir="$(profile_claude_dir "$_choice")"
              local _inc_proj=0
              confirm "  Copy projects too? [y/N] " && _inc_proj=1
              do_copy_settings "$src_dir" "$claude_dir" "$_choice" "$name" "$_inc_proj" || true
            else
              warn "Profile '$_choice' not found — skipping copy"
            fi
          fi
        fi
      fi

      # Auto-activate (lock → write_active → release)
      if [[ -t 0 ]]; then
        echo ""
        printf '%s' "  Set '$name' as active profile now? [Y/n] " >&2; read -r _activate
        _activate="${_activate%$'\r'}"
        if [[ ! "${_activate:-}" =~ ^[Nn]$ ]]; then
          echo ""
          lock_acquire
          write_active "$name"
          lock_release
          ok "Active profile → '$name'"
        fi
      fi
      ;;

    delete)
      lock_acquire
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: claude-proxy profile delete <n>"
      validate_name "$name" "profile name"
      [[ "$name" != "default" ]] || die "Cannot delete the 'default' profile.
  You can unset its proxy: claude-proxy profile unset-proxy default"
      require_profile "$name"
      local active; active="$(active_profile)"
      [[ "$name" != "$active" ]] || die "Cannot delete the active profile '$name'.
  Switch first: claude-proxy use <other-profile>"
      local claude_dir; claude_dir="$(profile_claude_dir "$name")"
      local proxy; proxy="$(read_conf "$PROFILES_DIR/${name}.conf" PROFILE_PROXY)"
      rm "$PROFILES_DIR/${name}.conf"
      ok "Profile '$name' deleted"
      info "Claude dir kept on disk: $(display_path "$claude_dir")"
      info "To also delete data: rm -rf $(display_path "$claude_dir")"
      [[ -n "$proxy" ]] && info "Proxy '$proxy' was linked — it still exists, not deleted"
      lock_release
      ;;

    use)
      lock_acquire
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: claude-proxy profile use <n>"
      validate_name "$name" "profile name"
      require_profile "$name"
      write_active "$name"
      local claude_dir; claude_dir="$(profile_claude_dir "$name")"
      local proxy; proxy="$(read_conf "$PROFILES_DIR/${name}.conf" PROFILE_PROXY)"
      ok "Switched to profile '$name'"
      info "Claude dir : $(display_path "$claude_dir")"
      info "Proxy      : ${proxy:-(no proxy)}"
      lock_release
      ;;

    show)
      local active; active="$(active_profile)"
      local target="${1:-$active}"
      if [[ -n "${1:-}" ]]; then
        validate_name "$target" "profile name"
        require_profile "$target"
      fi
      local claude_dir; claude_dir="$(profile_claude_dir "$target")"
      local proxy; proxy="$(read_conf "$PROFILES_DIR/${target}.conf" PROFILE_PROXY)"
      echo ""
      if [[ "$target" == "$active" ]]; then
        echo "  Profile        : $target  ◀ active"
      else
        echo "  Profile        : $target"
        echo "  Active profile : $active"
      fi
      echo "  Claude dir     : $(display_path "$claude_dir")"
      echo "  Proxy          : ${proxy:-(no proxy)}"
      if [[ -n "$proxy" ]]; then
        local pconf="$PROXIES_DIR/${proxy}.conf"
        if [[ -f "$pconf" ]]; then
          echo "  Proxy host     : $(read_conf "$pconf" PROXY_HOST)"
          echo "  Proxy user     : $(read_conf "$pconf" PROXY_USER)"
        else
          warn "Proxy '$proxy' config is missing!"
          info "Fix: claude-proxy profile unset-proxy $target"
        fi
      fi
      echo ""
      ;;

    set-proxy)
      lock_acquire
      local name="${1:-}" proxy="${2:-}"
      [[ -n "$name" && -n "$proxy" ]] || \
        die "Usage: claude-proxy profile set-proxy <profile> <proxy>"
      validate_name "$name"  "profile name"
      validate_name "$proxy" "proxy name"
      require_profile "$name"
      require_proxy   "$proxy"
      local claude_dir; claude_dir="$(profile_claude_dir "$name")"
      local gateway;    gateway="$(read_conf "$PROFILES_DIR/${name}.conf" PROFILE_GATEWAY)"
      write_profile_conf "$PROFILES_DIR/${name}.conf" "$claude_dir" "$proxy" "$gateway"
      ok "Profile '$name' → proxy '$proxy'"
      lock_release
      ;;

    unset-proxy)
      lock_acquire
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: claude-proxy profile unset-proxy <profile>"
      validate_name "$name" "profile name"
      require_profile "$name"
      local claude_dir; claude_dir="$(profile_claude_dir "$name")"
      local gateway;    gateway="$(read_conf "$PROFILES_DIR/${name}.conf" PROFILE_GATEWAY)"
      write_profile_conf "$PROFILES_DIR/${name}.conf" "$claude_dir" "" "$gateway"
      ok "Proxy removed from profile '$name' — will run without proxy"
      lock_release
      ;;

    copy-settings)
      local name="${1:-}"; shift || true
      [[ -n "$name" ]] || die "Usage: claude-proxy profile copy-settings <profile> --from <source> [--include-projects]"
      validate_name "$name" "profile name"
      local from_profile="" include_projects=0
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --from) shift; from_profile="${1:-}"; shift ;;
          --include-projects) include_projects=1; shift ;;
          *) die "Unknown option: $1" ;;
        esac
      done
      [[ -n "$from_profile" ]] || die "Usage: claude-proxy profile copy-settings <profile> --from <source> [--include-projects]"
      validate_name "$from_profile" "source profile name"
      [[ "$name" != "$from_profile" ]] || die "Cannot copy a profile to itself."
      require_profile "$name"
      require_profile "$from_profile"
      local src_dir; src_dir="$(profile_claude_dir "$from_profile")"
      local dst_dir; dst_dir="$(profile_claude_dir "$name")"
      if do_copy_settings "$src_dir" "$dst_dir" "$from_profile" "$name" "$include_projects"; then
        info "Note: you still need to log in to Claude in the new profile"
      fi
      ;;

    rename)
      lock_acquire
      local old="${1:-}" new="${2:-}"
      [[ -n "$old" && -n "$new" ]] || die "Usage: claude-proxy profile rename <old> <new>"
      validate_name "$old" "profile name"
      validate_name "$new" "profile name"
      [[ "$old" != "default" ]] || die "Cannot rename the 'default' profile."
      require_profile "$old"
      [[ ! -f "$PROFILES_DIR/${new}.conf" ]] || die "Profile '$new' already exists."

      local old_dir; old_dir="$(profile_claude_dir "$old")"
      local proxy;   proxy="$(read_conf   "$PROFILES_DIR/${old}.conf" PROFILE_PROXY)"
      local gateway; gateway="$(read_conf "$PROFILES_DIR/${old}.conf" PROFILE_GATEWAY)"

      local new_dir
      if [[ "$old_dir" == "$HOME/.claude-${old}" ]]; then
        new_dir="$HOME/.claude-${new}"
      else
        new_dir="$old_dir"
      fi

      if [[ "$old_dir" != "$new_dir" ]]; then
        if [[ -d "$old_dir" ]]; then
          [[ ! -e "$new_dir" ]] || \
            die "Cannot move Claude dir: '$new_dir' already exists. Move it manually first."
          mv "$old_dir" "$new_dir"
          info "Claude dir moved: $old_dir → $new_dir"
        else
          info "Claude dir '$old_dir' not found — skipping move"
          info "New dir will be: $new_dir (created on first use)"
        fi
      fi

      write_profile_conf "$PROFILES_DIR/${new}.conf" "$new_dir" "$proxy" "$gateway"
      rm "$PROFILES_DIR/${old}.conf"

      local active; active="$(active_profile)"
      if [[ "$active" == "$old" ]]; then
        write_active "$new"
        info "Active profile updated → '$new'"
      fi
      ok "Profile '$old' renamed → '$new'"
      lock_release
      ;;

    *)
      cat <<'EOF'
Usage:
  claude-proxy profile list
  claude-proxy profile create <n> [--from <source>] [--include-projects]
  claude-proxy profile delete <n>
  claude-proxy profile rename  <old> <new>
  claude-proxy profile use     <n>
  claude-proxy profile show    [<n>]
  claude-proxy profile set-proxy     <profile> <proxy>
  claude-proxy profile unset-proxy   <profile>
  claude-proxy profile copy-settings <profile> --from <source> [--include-projects]
EOF
      exit 1
      ;;
  esac
}

# ── proxy subcommands ────────────────────────────────────────────────────────

cmd_proxy() {
  local sub="${1:-}"; shift || true

  case "$sub" in

    list)
      ensure_dirs
      shopt -s nullglob
      local files=("$PROXIES_DIR"/*.conf)
      shopt -u nullglob
      if [[ ${#files[@]} -eq 0 ]]; then
        echo "  (no proxies yet — run: claude-proxy proxy create <n> <host:port> <user>)"
        return
      fi
      echo ""
      printf "  %-20s  %-38s  %s\n" "PROXY" "HOST" "USED BY PROFILES"
      printf "  %-20s  %-38s  %s\n" "-----" "----" "----------------"
      for f in "${files[@]}"; do
        local pname; pname="$(basename "$f" .conf)"
        local phost; phost="$(read_conf "$f" PROXY_HOST)"
        local puser; puser="$(read_conf "$f" PROXY_USER)"
        local used_by; used_by="$(profiles_using_proxy "$pname")"
        printf "  %-20s  %-38s  %s\n" \
          "$pname" "${puser:-?}@${phost:-?}" "${used_by:-(unused)}"
      done
      echo ""
      ;;

    create)
      require_interactive
      local name="${1:-}" host="${2:-}" user="${3:-}"
      [[ -n "$name" && -n "$host" && -n "$user" ]] || \
        die "Usage: claude-proxy proxy create <n> <host:port> <user>"
      validate_name "$name" "proxy name"
      [[ "$host" =~ ^[^:]+:[0-9]+$ ]] || \
        die "Invalid host format '$host'. Expected hostname:PORT (e.g. 10.0.0.1:3128)"
      ensure_dirs
      local conf="$PROXIES_DIR/${name}.conf"
      local svc; svc="$(keychain_service "$name")"
      # Fast-fail before prompting (non-atomic; re-checked under lock below)
      [[ ! -f "$conf" ]] || die "Proxy '$name' already exists. View: claude-proxy proxy show $name"
      # Prompt for password BEFORE acquiring lock — avoids holding lock during
      # unbounded interactive input. Conf is written only after password is stored.
      echo "Creating proxy '$name' ($user@$host)"
      echo "Enter proxy password (stored in macOS Keychain):"
      security add-generic-password -a "$user" -s "$svc" -U -w
      # Now acquire lock and write conf atomically
      lock_acquire
      if [[ -f "$conf" ]]; then
        # TOCTOU: conf appeared between our pre-check and lock_acquire.
        # Release lock explicitly before die — EXIT trap won't fire here.
        security delete-generic-password -a "$user" -s "$svc" 2>/dev/null || true
        lock_release
        die "Proxy '$name' already exists (created concurrently). View: claude-proxy proxy show $name"
      fi
      write_proxy_conf "$conf" "$host" "$user" "$svc"
      ok "Proxy '$name' created"
      info "Keychain service : $svc"
      info "Link to a profile: claude-proxy profile set-proxy <profile> $name"
      lock_release
      ;;

    delete)
      lock_acquire
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: claude-proxy proxy delete <n>"
      validate_name "$name" "proxy name"
      require_proxy "$name"

      local used_by; used_by="$(profiles_using_proxy "$name")"
      if [[ -n "$used_by" ]]; then
        warn "Proxy '$name' is used by profile(s): $used_by"
        warn "Those profiles will be unlinked and run without a proxy."
        require_interactive
        confirm "Delete anyway? [y/N] " || { echo "Aborted."; exit 0; }
        echo ""
        # Unlink from all profiles before deleting
        unlink_proxy_from_profiles "$name"
      fi

      local puser; puser="$(read_conf "$PROXIES_DIR/${name}.conf" PROXY_USER)"
      local psvc;  psvc="$(read_conf  "$PROXIES_DIR/${name}.conf" PROXY_KEYCHAIN_SERVICE)"
      psvc="${psvc:-$(keychain_service "$name")}"
      if security delete-generic-password -a "${puser:-}" -s "$psvc" >/dev/null 2>&1; then
        info "Keychain entry removed"
      else
        info "Keychain entry not found (skipped)"
      fi
      rm "$PROXIES_DIR/${name}.conf"
      ok "Proxy '$name' deleted"
      lock_release
      ;;

    set-password)
      require_interactive
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: claude-proxy proxy set-password <n>"
      validate_name "$name" "proxy name"
      require_proxy "$name"
      local puser; puser="$(read_conf "$PROXIES_DIR/${name}.conf" PROXY_USER)"
      local psvc;  psvc="$(read_conf  "$PROXIES_DIR/${name}.conf" PROXY_KEYCHAIN_SERVICE)"
      psvc="${psvc:-$(keychain_service "$name")}"
      echo "Enter new password for proxy '$name' (user: ${puser:-?}):"
      security add-generic-password -a "$puser" -s "$psvc" -U -w
      ok "Password updated in Keychain"
      ;;

    show)
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: claude-proxy proxy show <n>"
      validate_name "$name" "proxy name"
      require_proxy "$name"
      local phost; phost="$(read_conf "$PROXIES_DIR/${name}.conf" PROXY_HOST)"
      local puser; puser="$(read_conf "$PROXIES_DIR/${name}.conf" PROXY_USER)"
      local psvc;  psvc="$(read_conf  "$PROXIES_DIR/${name}.conf" PROXY_KEYCHAIN_SERVICE)"
      psvc="${psvc:-$(keychain_service "$name")}"
      local has_pass="no"
      security find-generic-password -a "$puser" -s "$psvc" -w &>/dev/null && has_pass="yes"
      echo ""
      echo "  Proxy            : $name"
      echo "  Host             : ${phost:-?}"
      echo "  User             : ${puser:-?}"
      echo "  Keychain service : $psvc"
      echo "  Password in KC   : $has_pass"
      echo ""
      ;;

    check)
      local name="${1:-}"
      [[ -n "$name" ]] || die "Usage: claude-proxy proxy check <n>"
      validate_name "$name" "proxy name"
      require_proxy "$name"
      local phost; phost="$(read_conf "$PROXIES_DIR/${name}.conf" PROXY_HOST)"
      local puser; puser="$(read_conf "$PROXIES_DIR/${name}.conf" PROXY_USER)"
      local psvc;  psvc="$(read_conf  "$PROXIES_DIR/${name}.conf" PROXY_KEYCHAIN_SERVICE)"
      psvc="${psvc:-$(keychain_service "$name")}"
      local pass
      pass="$(security find-generic-password -a "$puser" -s "$psvc" -w 2>/dev/null || true)"
      [[ -n "$pass" ]] || die "Password not found in Keychain for proxy '$name'.
  Fix: claude-proxy proxy set-password $name"

      local proxy_ip="${phost%%:*}"
      local proxy_port="${phost##*:}"
      [[ "$proxy_port" =~ ^[0-9]+$ ]] || die "Invalid proxy host '$phost'. Expected hostname:PORT"

      echo ""
      echo "Checking proxy '$name' ($puser@$phost)..."
      echo ""

      # 1. TCP
      printf "  %-44s" "TCP connect to $proxy_ip:$proxy_port ..."
      if ! command -v nc >/dev/null 2>&1; then
        echo "⚠️  skipped (nc not available)"
      elif nc -z -w 5 "$proxy_ip" "$proxy_port" 2>/dev/null; then
        echo "✅ OK"
      else
        echo "❌ FAILED (host unreachable or port closed)"; exit 1
      fi

      local proxy_url="http://$(url_encode "$puser"):$(url_encode "$pass")@${phost}"

      # 2. Proxy auth
      printf "  %-44s" "Proxy authentication ..."
      local auth_code
      auth_code="$(curl -s -o /dev/null -w "%{http_code}" \
        --max-time 10 --proxy "$proxy_url" \
        "http://api.anthropic.com" 2>/dev/null || echo "000")"
      case "$auth_code" in
        407) echo "❌ FAILED — proxy rejected credentials (HTTP 407)"
             info "Fix: claude-proxy proxy set-password $name"; exit 1 ;;
        000) echo "⚠️  No response to plain HTTP (expected for strict CONNECT-only proxies — checking tunnel next...)" ;;
        *)   echo "✅ OK (HTTP $auth_code)" ;;
      esac

      # 3. Anthropic API via CONNECT tunnel
      printf "  %-44s" "Anthropic API via CONNECT tunnel ..."
      local api_code
      api_code="$(curl -s -o /dev/null -w "%{http_code}" \
        --max-time 15 --proxy "$proxy_url" --proxytunnel \
        "https://api.anthropic.com/v1/models" \
        -H "x-api-key: invalid-check" \
        -H "anthropic-version: 2023-06-01" 2>/dev/null || echo "000")"
      case "$api_code" in
        200|401|403) echo "✅ OK (HTTP $api_code — API reachable)" ;;
        407) echo "❌ FAILED — proxy auth rejected (HTTP 407)"
             info "Fix: claude-proxy proxy set-password $name"; exit 1 ;;
        000) echo "❌ FAILED — timeout or no response"; exit 1 ;;
        *)   echo "⚠️  HTTP $api_code — unexpected, but tunnel may work" ;;
      esac

      echo ""
      ok "Proxy '$name' looks good."
      echo ""
      ;;

    rename)
      lock_acquire
      local old="${1:-}" new="${2:-}"
      [[ -n "$old" && -n "$new" ]] || die "Usage: claude-proxy proxy rename <old> <new>"
      validate_name "$old" "proxy name"
      validate_name "$new" "proxy name"
      require_proxy "$old"
      [[ ! -f "$PROXIES_DIR/${new}.conf" ]] || die "Proxy '$new' already exists."
      local phost; phost="$(read_conf "$PROXIES_DIR/${old}.conf" PROXY_HOST)"
      local puser; puser="$(read_conf "$PROXIES_DIR/${old}.conf" PROXY_USER)"
      local old_svc; old_svc="$(read_conf "$PROXIES_DIR/${old}.conf" PROXY_KEYCHAIN_SERVICE)"
      old_svc="${old_svc:-$(keychain_service "$old")}"
      local new_svc; new_svc="$(keychain_service "$new")"

      # Migrate Keychain entry
      local pass
      pass="$(security find-generic-password -a "$puser" -s "$old_svc" -w 2>/dev/null || true)"
      if [[ -n "$pass" ]]; then
        security add-generic-password -a "$puser" -s "$new_svc" -w "$pass" -U >/dev/null 2>&1 || true
        security delete-generic-password -a "$puser" -s "$old_svc" >/dev/null 2>&1 || true
        info "Keychain entry renamed: $old_svc → $new_svc"
      else
        warn "Could not migrate Keychain entry — run: claude-proxy proxy set-password $new"
      fi

      write_proxy_conf "$PROXIES_DIR/${new}.conf" "$phost" "$puser" "$new_svc"
      rm "$PROXIES_DIR/${old}.conf"

      # Update linked profiles
      shopt -s nullglob
      for pf in "$PROFILES_DIR"/*.conf; do
        local linked; linked="$(read_conf "$pf" PROFILE_PROXY)"
        if [[ "$linked" == "$old" ]]; then
          local pdir;    pdir="$(read_conf    "$pf" PROFILE_CLAUDE_DIR)"
          local gateway; gateway="$(read_conf "$pf" PROFILE_GATEWAY)"
          write_profile_conf "$pf" "$pdir" "$new" "$gateway"
          info "Updated profile '$(basename "$pf" .conf)' → proxy '$new'"
        fi
      done
      shopt -u nullglob
      ok "Proxy '$old' renamed → '$new'"
      lock_release
      ;;

    *)
      cat <<'EOF'
Usage:
  claude-proxy proxy list
  claude-proxy proxy create <n> <host:port> <user>
  claude-proxy proxy delete <n>
  claude-proxy proxy rename  <old> <new>
  claude-proxy proxy set-password <n>
  claude-proxy proxy show  <n>
  claude-proxy proxy check <n>
EOF
      exit 1
      ;;
  esac
}

cmd_update() {
  local _target_version="" _label="Latest" _force=0

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version)
        [[ -n "${2:-}" ]] || die "Usage: claude-proxy update [--force] [--version <tag>]"
        _target_version="${2#v}"; _target_version="v${_target_version}"; _label="Target"; shift 2 ;;
      --force) _force=1; shift ;;
      *)
        die "Unknown option: $1
Usage: claude-proxy update [--force] [--version <tag>]" ;;
    esac
  done

  require_interactive

  # Fetch latest release from GitHub if no version pinned.
  # NOTE: identical fetch logic exists in install.sh — keep both in sync if the API path changes.
  if [[ -z "$_target_version" ]]; then
    local _fetched
    _fetched="$(curl -fsSL --proto '=https' --tlsv1.2 \
      "https://api.github.com/repos/r0mm4k/proxied-claude/releases/latest" \
      2>/dev/null \
      | sed -n 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
    [[ -n "$_fetched" ]] || die "Could not fetch latest release from GitHub.
Pin a version explicitly:
  claude-proxy update --version vX.Y.Z"
    _target_version="$_fetched"
  fi

  # Already up to date?
  local _installed="v$VERSION"
  if [[ "$_installed" == "$_target_version" && "$_force" -eq 0 ]]; then
    echo "Already up to date: $_installed"
    return 0
  fi

  # Version preview
  echo ""
  echo "  Installed : $_installed"
  echo "  $_label    : $_target_version"
  echo ""

  # Major version bump warning
  local _inst_major _new_major
  _inst_major="${VERSION%%.*}"
  _new_major="${_target_version#v}"; _new_major="${_new_major%%.*}"
  if [[ "$_new_major" =~ ^[0-9]+$ && "$_inst_major" =~ ^[0-9]+$ && "$_new_major" -gt "$_inst_major" ]]; then
    warn "Major version upgrade ($_installed → $_target_version)."
    echo "   Review release notes before upgrading:"
    echo "   https://github.com/r0mm4k/proxied-claude/releases/tag/${_target_version}"
    echo ""
  fi

  # Detect direction: reinstall / downgrade / upgrade
  local _lo _prompt_verb _prompt_to="to "
  if [[ "$_installed" == "$_target_version" ]]; then
    _prompt_verb="Reinstall"
    _prompt_to=""
  else
    _lo="$(printf '%s\n%s\n' "${VERSION}" "${_target_version#v}" | sort -V | head -1)"
    if [[ "$_lo" == "${_target_version#v}" ]]; then
      _prompt_verb="Downgrade"
    else
      _prompt_verb="Upgrade"
    fi
  fi
  confirm "$_prompt_verb ${_prompt_to}$_target_version? [y/N] " || { echo "Aborted."; return 0; }

  # Install
  echo ""
  echo "Your profiles, proxies and settings are preserved."
  echo ""
  _TMP="$(mktemp)"
  trap 'rm -f "$_TMP"' EXIT
  curl -fsSL --proto '=https' --tlsv1.2 \
    "https://raw.githubusercontent.com/r0mm4k/proxied-claude/${_target_version}/install.sh" \
    -o "$_TMP"
  VERSION="$_target_version" PROXIED_CLAUDE_UPGRADE=1 bash "$_TMP"
  rm -f "$_TMP"
  trap - EXIT
}

cmd_status() {
  local _active; _active="$(active_profile)"
  local _dir;    _dir="$(profile_claude_dir "$_active")"
  local _proxy;  _proxy="$(read_conf "$PROFILES_DIR/${_active}.conf" PROFILE_PROXY)"
  echo ""
  echo "  ── Active profile ─────────────────────────────"
  echo "  Profile    : $_active"
  echo "  Claude dir : $(display_path "$_dir")"
  echo "  Proxy      : ${_proxy:-(no proxy)}"
  if [[ -n "$_proxy" ]]; then
    local _pconf="$PROXIES_DIR/${_proxy}.conf"
    if [[ -f "$_pconf" ]]; then
      echo "  Host       : $(read_conf "$_pconf" PROXY_HOST)"
      echo "  User       : $(read_conf "$_pconf" PROXY_USER)"
    else
      warn "Proxy '$_proxy' config is missing!"
    fi
  fi
  echo ""
  echo "  ── All profiles ───────────────────────────────"
  shopt -s nullglob
  local -a _pfiles=("$PROFILES_DIR"/*.conf)
  shopt -u nullglob
  if [[ ${#_pfiles[@]} -eq 0 ]]; then
    echo "  (none)"
  else
    local _f _n _lp _marker
    for _f in "${_pfiles[@]}"; do
      _n="$(basename "$_f" .conf)"
      _lp="$(read_conf "$_f" PROFILE_PROXY)"
      _marker=""; [[ "$_n" == "$_active" ]] && _marker=" ◀"
      printf "  %-20s  %s%s\n" "$_n" "${_lp:-(no proxy)}" "$_marker"
    done
  fi
  echo ""
  echo "  ── All proxies ────────────────────────────────"
  shopt -s nullglob
  local -a _xfiles=("$PROXIES_DIR"/*.conf)
  shopt -u nullglob
  if [[ ${#_xfiles[@]} -eq 0 ]]; then
    echo "  (none)"
  else
    local _f _n _h _u
    for _f in "${_xfiles[@]}"; do
      _n="$(basename "$_f" .conf)"
      _h="$(read_conf "$_f" PROXY_HOST)"
      _u="$(read_conf "$_f" PROXY_USER)"
      printf "  %-20s  %s@%s\n" "$_n" "${_u:-?}" "${_h:-?}"
    done
  fi
  echo ""
  echo "  ── IDE integration ────────────────────────────"
  echo "  Command    : $WRAPPER_PATH"
  echo "  Config dir : $CONF_DIR"
  echo ""
}

cmd_check() {
  local _active; _active="$(active_profile)"
  local _proxy;  _proxy="$(read_conf "$PROFILES_DIR/${_active}.conf" PROFILE_PROXY)"
  [[ -n "$_proxy" ]] || die "Active profile '$_active' has no proxy linked.
  Link one: claude-proxy profile set-proxy $_active <proxy>"
  cmd_proxy check "$_proxy"
}

cmd_run() {
  [[ -n "${1:-}" ]] || die "Usage: claude-proxy run <profile>"
  local _profile="$1"; shift || true
  validate_name "$_profile" "profile name"
  require_profile "$_profile"
  PROXIED_CLAUDE_PROFILE="$_profile" exec "$WRAPPER_PATH" "$@"
}

# ── Top-level dispatch ───────────────────────────────────────────────────────

ensure_default_profile

cmd="${1:-}"; shift || true

case "$cmd" in
  profile) cmd_profile "$@" ;;
  proxy)   cmd_proxy   "$@" ;;

  use)
    [[ -n "${1:-}" ]] || die "Usage: claude-proxy use <profile>"
    cmd_profile use "$1"
    ;;

  status) cmd_status ;;

  check) cmd_check ;;

  version|--version|-v)
    echo "claude-proxy $VERSION"
    ;;

  help|--help|-h)
    print_help
    ;;

  migrate)
    lock_acquire
    do_migrate 1
    lock_release
    ;;

  update) cmd_update "$@" ;;

  uninstall)
    echo "This will remove:"
    echo "  $WRAPPER_PATH"
    echo "  $CTL_PATH"
    echo "  $CONF_DIR (all profiles, proxy configs, active_profile, shared ide/)"
    echo "  All Keychain entries for managed proxies"
    echo ""
    echo "Will NOT delete: ~/.claude  ~/.claude-*  (your Claude account data)"
    echo ""
    require_interactive
    confirm "Are you sure? [y/N] " || { echo "Aborted."; exit 0; }

    shopt -s nullglob
    for f in "$PROXIES_DIR"/*.conf; do
      _u="$(read_conf "$f" PROXY_USER)"
      _s="$(read_conf "$f" PROXY_KEYCHAIN_SERVICE)"
      _s="${_s:-$(keychain_service "$(basename "$f" .conf)")}"
      security delete-generic-password -a "${_u:-}" -s "$_s" >/dev/null 2>&1 && \
        info "Keychain removed: $_s" || true
    done
    shopt -u nullglob

    [[ -f "$WRAPPER_PATH" ]] && { sudo rm -f "$WRAPPER_PATH"; ok "Removed $WRAPPER_PATH"; } || true
    [[ -f "$CTL_PATH" ]]     && { sudo rm -f "$CTL_PATH";     ok "Removed $CTL_PATH";     } || true
    [[ -d "$CONF_DIR" ]]     && { rm -rf "$CONF_DIR";         ok "Removed $CONF_DIR";     } || true
    echo ""
    ok "Uninstalled. Your Claude account dirs (~/.claude*) were kept."
    ;;

  run) cmd_run "$@" ;;

  "")
    print_help
    ;;

  *)
    # Friendly hint for v1 users who still use old commands
    case "$cmd" in
      set-all|set-host|set-user)
        echo "ERROR: '$cmd' was a v1 command. Use instead:" >&2
        echo "  claude-proxy proxy create <n> <host:port> <user>" >&2
        exit 1 ;;
      set-password)
        echo "ERROR: '$cmd' was a v1 command. Use instead:" >&2
        echo "  claude-proxy proxy set-password default" >&2
        exit 1 ;;
    esac
    die "Unknown command: $cmd
  Run: claude-proxy help"
    ;;
esac
